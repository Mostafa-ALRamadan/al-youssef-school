{
	"info": {
		"_postman_id": "suggestions-api",
		"name": "Suggestions API",
		"description": "API collection for testing suggestions with rate limiting",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"item": [
		{
			"name": "Login",
			"request": {
				"method": "POST",
				"header": [
					{
						"key": "Content-Type",
						"value": "application/json"
					}
				],
				"body": {
					"mode": "raw",
					"raw": "{\n  \"email\": \"parent@example.com\",\n  \"password\": \"password123\"\n}"
				},
				"url": {
					"raw": "http://localhost:3000/api/auth/login",
					"host": [
						"localhost"
					],
					"port": "3000",
					"path": [
						"api",
						"auth",
						"login"
					]
				}
			},
			"response": []
		},
		{
			"name": "Get Suggestions (Admin)",
			"request": {
				"method": "GET",
				"header": [
					{
						"key": "Authorization",
						"value": "Bearer {{auth_token}}"
					}
				],
				"url": {
					"raw": "http://localhost:3000/api/suggestions",
					"host": [
						"localhost"
					],
					"port": "3000",
					"path": [
						"api",
						"suggestions"
					]
				}
			},
			"response": []
		},
		{
			"name": "Create Suggestion",
			"request": {
				"method": "POST",
				"header": [
					{
						"key": "Content-Type",
						"value": "application/json"
					},
					{
						"key": "Authorization",
						"value": "Bearer {{auth_token}}"
					}
				],
				"body": {
					"mode": "raw",
					"raw": "{\n  \"title\": \"Test Suggestion\",\n  \"message\": \"This is a test suggestion from Postman\"\n}"
				},
				"url": {
					"raw": "http://localhost:3000/api/suggestions",
					"host": [
						"localhost"
					],
					"port": "3000",
					"path": [
						"api",
						"suggestions"
					]
				}
			},
			"response": []
		},
		{
			"name": "Create Suggestion (Rate Limit Test)",
			"request": {
				"method": "POST",
				"header": [
					{
						"key": "Content-Type",
						"value": "application/json"
					},
					{
						"key": "Authorization",
						"value": "Bearer {{auth_token}}"
					}
				],
				"body": {
					"mode": "raw",
					"raw": "{\n  \"title\": \"Rate Limit Test {{iteration}}\",\n  \"message\": \"Testing rate limit iteration {{iteration}}\"\n}"
				},
				"url": {
					"raw": "http://localhost:3000/api/suggestions",
					"host": [
						"localhost"
					],
					"port": "3000",
					"path": [
						"api",
						"suggestions"
					]
				}
			},
			"response": []
		},
		{
			"name": "Create Suggestion (No Auth - Should Fail)",
			"request": {
				"method": "POST",
				"header": [
					{
						"key": "Content-Type",
						"value": "application/json"
					}
				],
				"body": {
					"mode": "raw",
					"raw": "{\n  \"title\": \"No Auth Test\",\n  \"message\": \"This should fail with 401\"\n}"
				},
				"url": {
					"raw": "http://localhost:3000/api/suggestions",
					"host": [
						"localhost"
					],
					"port": "3000",
					"path": [
						"api",
						"suggestions"
					]
				}
			},
			"response": []
		}
	],
	"variable": [
		{
			"key": "auth_token",
			"value": "",
			"type": "string"
		}
	]
}
